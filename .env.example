# Backend
BACKEND_PORT=8787

# OpenAI-compatible NewAPI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# PaddleOCR-VL
PADDLEOCR_TOKEN=
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_MODEL=PaddleOCR-VL-1.6

# MinIO document object storage
MINIO_ENDPOINT=http://106.14.226.88:9000
MINIO_PUBLIC_ENDPOINT=http://106.14.226.88:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=construction-review-docs
MINIO_REGION=us-east-1

# Optional Python agent service bridge
AGENT_SERVICE_BASE_URL=
AGENT_SERVICE_TIMEOUT_MS=5000

# Optional document conversion HTTP tools
# Local example: http://localhost:5000
# Online/offline deployments can swap this base URL without frontend changes.
HTTP_TOOLS_BASE_URL=
HTTP_TOOLS_TIMEOUT_MS=30000
HTTP_TOOLS_DOCX2HTML_PATH=/api/capabilities/docx2html
HTTP_TOOLS_HTML2DOCX_PATH=/api/capabilities/html2docx
